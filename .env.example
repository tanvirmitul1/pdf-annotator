# PostgreSQL (used by Prisma runtime and migrations)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/pdf_annotator?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/pdf_annotator?schema=public"

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-this-with-a-32-character-secret"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Redis / Upstash
REDIS_URL="redis://localhost:6381"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Storage
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./uploads"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""

# Email
RESEND_API_KEY=""
EMAIL_FROM="PDF Annotator <no-reply@example.com>"

# Observability
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
POSTHOG_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# App behavior
APP_ENV="development"
APP_URL="http://localhost:3000"
LOG_LEVEL="info"

# Production-only extras
CRON_SECRET=""
ADMIN_EMAILS=""
