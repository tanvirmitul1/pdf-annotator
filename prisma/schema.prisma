generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ErrorType {
  VALIDATION_ERROR
  AUTHENTICATION_ERROR
  AUTHORIZATION_ERROR
  NOT_FOUND_ERROR
  RATE_LIMIT_ERROR
  DATABASE_ERROR
  EXTERNAL_API_ERROR
  FILE_UPLOAD_ERROR
  PROCESSING_ERROR
  INTERNAL_SERVER_ERROR
  UNKNOWN_ERROR
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum UsageMetric {
  DOCUMENTS
  STORAGE_MB
  SHARE_LINKS
  ANNOTATIONS
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

enum AnnotationType {
  HIGHLIGHT
  UNDERLINE
  STRIKETHROUGH
  SQUIGGLY
  NOTE
  FREEHAND
  RECTANGLE
  CIRCLE
  ARROW
  TEXTBOX
  IMAGE_SHAPE
  SIGNATURE
  REDACTION
  CHECKMARK
  CROSS
  LINE
  STAMP
  CLOUD
}

enum AnnotationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum DocumentMemberRole {
  VIEWER
  COMMENTER
  EDITOR
}

enum ExportJobKind {
  DATA_EXPORT
  ANNOTATION_EXPORT
  PDF_EXPORT
}

enum ExportJobStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
}

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ServiceType {
  DOCUMENTS
  AI_CHAT
}

model User {
  id                 String             @id @default(cuid())
  name               String?
  email              String?            @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  isAnonymous        Boolean            @default(false)
  deviceToken        String?            @unique
  lastKnownIp        String?
  role               UserRole           @default(USER)
  planId             String             @default("free")
  trialEndsAt        DateTime?
  subscriptionStatus SubscriptionStatus @default(FREE)
  stripeCustomerId   String?
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  plan               Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  accounts           Account[]
  sessions           Session[]
  usage              Usage[]
  documents          Document[]
  annotations        Annotation[]
  assignedAnnotations Annotation[]       @relation("AnnotationAssignee")
  comments           AnnotationComment[]
  mentions           CommentMention[]
  reactions          CommentReaction[]
  notifications      Notification[]
  tags               Tag[]
  collections        Collection[]
  bookmarks          Bookmark[]
  readingProgress    ReadingProgress[]
  shareLinks         ShareLink[]
  documentMemberships DocumentMember[]
  exportJobs         ExportJob[]
  emailLogs          EmailLog[]
  auditLogs          AuditLog[]
  apiKeys            ApiKey[]
  errorLogs          ErrorLog[]
  resolvedErrors     ErrorLog[]        @relation("ErrorResolver")
  conversations      Conversation[]
  messages           Message[]
  chatAttachments    ChatAttachment[]
  userMemories       UserMemory[]
  userSettings       UserSettings?
  chatFolders        ChatFolder[]
  savedPrompts       SavedPrompt[]
  sharedConversations SharedConversation[]
  chatUsageLogs      ChatUsageLog[]
  serviceAccess      UserServiceAccess[]
  userTokens         UserToken[]

  @@index([planId])
  @@index([deletedAt])
  @@index([isAnonymous])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@index([token])
}

model UserToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, type])
}

model Plan {
  id        String   @id
  name      String   @unique
  price     Int      @default(0)
  limits    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Usage {
  id          String      @id @default(cuid())
  userId      String
  metric      UsageMetric
  value       Int         @default(0)
  periodStart DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metric])
  @@index([userId])
}

model Document {
  id            String         @id @default(cuid())
  userId        String
  name          String
  pageCount     Int            @default(0)
  fileSize      Int            @default(0)
  storageKey    String
  thumbnailKey  String?
  lastOpenedAt  DateTime?
  status             DocumentStatus @default(PROCESSING)
  processingProgress Int            @default(0)
  deletedAt          DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  annotations   Annotation[]
  collections   DocumentCollection[]
  bookmarks     Bookmark[]
  reading       ReadingProgress[]
  shareLinks    ShareLink[]
  members       DocumentMember[]
  textPages     DocumentText[]
  outline       DocumentOutline?
  pageOrder     Json? // Array of { originalIndex: number, rotation: number, deleted: boolean }

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, lastOpenedAt(sort: Desc)])
}

model Annotation {
  id           String         @id @default(cuid())
  clientId     String?        @unique // For idempotent upserts
  userId       String
  assigneeId   String?
  documentId   String
  pageNumber   Int
  type         AnnotationType
  status       AnnotationStatus @default(OPEN)
  color        String
  positionData Json
  content      String?
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignee     User?          @relation("AnnotationAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  document     Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tags         AnnotationTag[]
  comments     AnnotationComment[]

  @@index([userId])
  @@index([assigneeId])
  @@index([userId, deletedAt])
  @@index([documentId])
}

model Tag {
  id          String          @id @default(cuid())
  userId      String
  label       String
  color       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  annotations AnnotationTag[]

  @@index([userId])
  @@unique([userId, label])
}

model AnnotationTag {
  annotationId String
  tagId        String
  annotation   Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  tag          Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([annotationId, tagId])
  @@index([tagId])
}

model Collection {
  id         String               @id @default(cuid())
  userId     String
  name       String
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents  DocumentCollection[]

  @@index([userId])
  @@unique([userId, name])
}

model DocumentCollection {
  documentId   String
  collectionId String
  document     Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([documentId, collectionId])
  @@index([collectionId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  documentId String
  pageNumber Int
  label      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
}

model ReadingProgress {
  id              String   @id @default(cuid())
  userId          String
  documentId      String
  lastPage        Int
  percentComplete Float
  lastReadAt      DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([userId])
  @@index([documentId])
}

model ShareLink {
  id           String   @id @default(cuid())
  userId       String
  documentId   String
  token        String   @unique
  createdBy    String
  expiresAt    DateTime?
  viewCount    Int      @default(0)
  revokedAt    DateTime?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
}

model DocumentMember {
  id         String             @id @default(cuid())
  documentId String
  userId     String
  role       DocumentMemberRole @default(VIEWER)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  resourceType String
  resourceId   String
  metadata     Json
  ipAddress    String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

model DocumentText {
  id         String                  @id @default(cuid())
  documentId String
  pageNumber Int
  text       String
  objects    Json?                   // Array of { type: 'text'|'image', x, y, width, height, id, ... }
  tsv        Unsupported("tsvector")?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  document   Document                @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber])
  @@index([documentId])
}

model DocumentOutline {
  id         String   @id @default(cuid())
  documentId String   @unique
  entries    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ExportJob {
  id         String          @id @default(cuid())
  userId     String
  kind       ExportJobKind
  status     ExportJobStatus @default(QUEUED)
  payload    Json
  resultKey  String?
  error      String?
  progress   Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventId     String   @unique
  payload     Json
  processedAt DateTime?
  createdAt   DateTime @default(now())
}

model EmailLog {
  id         String         @id @default(cuid())
  userId     String
  template   String
  status     EmailLogStatus @default(QUEUED)
  provider   String
  providerId String?
  error      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AnnotationComment {
  id           String              @id @default(cuid())
  annotationId String
  userId       String
  parentId     String?
  content      String
  editedAt     DateTime?
  deletedAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  annotation   Annotation          @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       AnnotationComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      AnnotationComment[] @relation("CommentReplies")
  mentions     CommentMention[]
  reactions    CommentReaction[]

  @@index([annotationId])
  @@index([userId])
  @@index([parentId])
  @@index([annotationId, createdAt(sort: Asc)])
  @@index([annotationId, parentId, createdAt(sort: Asc)])
}

model CommentMention {
  id        String            @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime          @default(now())
  comment   AnnotationComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model CommentReaction {
  id        String            @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime          @default(now())
  comment   AnnotationComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
  @@index([userId])
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  type         String
  title        String
  body         String
  annotationId String?
  commentId    String?
  actorId      String?
  readAt       DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  prefix     String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ErrorLog {
  id            String    @id @default(cuid())
  userId        String?
  userEmail     String?
  userName      String?
  errorType     ErrorType
  errorCode     String?
  message       String
  stack         String?   @db.Text
  url           String?
  method        String?
  statusCode    Int?
  userAgent     String?
  ipAddress     String
  metadata      Json?
  resolved      Boolean   @default(false)
  resolvedBy    String?
  resolvedAt    DateTime?
  resolvedNotes String?   @db.Text
  createdAt     DateTime  @default(now())
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  resolver      User?     @relation("ErrorResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([errorType])
  @@index([createdAt(sort: Desc)])
  @@index([resolved])
}

// ============================================
// AI CHAT PLATFORM MODELS
// ============================================

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ChatModel {
  GEMMA_LOCAL
  GEMMA_GATEWAY
  GPT_4
  GPT_4_TURBO
  GPT_3_5_TURBO
  CLAUDE_3_OPUS
  CLAUDE_3_SONNET
  CLAUDE_3_HAIKU
  GEMINI_PRO
  GEMINI_ULTRA
  DEEPSEEK_CHAT
  LLAMA_3_70B
  MISTRAL_LARGE
}

model Conversation {
  id          String               @id @default(cuid())
  userId      String
  title       String               @default("New Chat")
  model       ChatModel            @default(GEMMA_LOCAL)
  folderId    String?
  pinned      Boolean              @default(false)
  archived    Boolean              @default(false)
  archivedAt  DateTime?
  metadata    Json?                // Store extra settings like temperature, system prompt, etc.
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      ChatFolder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messages    Message[]
  attachments ChatAttachment[]
  shared      SharedConversation[]

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, pinned])
  @@index([userId, archived])
  @@index([folderId])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  userId         String
  role           MessageRole
  content        String         @db.Text
  model          ChatModel?
  tokenCount     Int?           // Tokens used for this message
  metadata       Json?          // Store tool calls, function results, etc.
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments    ChatAttachment[]

  @@index([conversationId])
  @@index([userId])
  @@index([conversationId, createdAt(sort: Asc)])
}

model ChatAttachment {
  id                  String       @id @default(cuid())
  userId              String
  conversationId      String
  messageId           String?
  fileName            String
  mimeType            String
  fileSize            Int
  cloudinaryPublicId  String       // Cloudinary public_id
  cloudinaryUrl       String       // Cloudinary secure_url
  ocrText             String?      @db.Text // Extracted OCR text for images
  metadata            Json?        // Store processing results, dimensions, etc.
  createdAt           DateTime     @default(now())
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message             Message?     @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([messageId])
}

model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  key       String   // Memory topic/key
  value     String   @db.Text // Memory content
  metadata  Json?    // Store context, source conversation, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model UserSettings {
  id                   String    @id @default(cuid())
  userId               String    @unique
  theme                String    @default("system") // light | dark | system
  defaultModel         ChatModel @default(GEMMA_LOCAL)
  language             String    @default("en")
  temperature          Float     @default(0.7)
  systemInstructions   String?   @db.Text
  enableMemory         Boolean   @default(false)
  sidebarCollapsed     Boolean   @default(false)
  notificationsEnabled Boolean   @default(true)
  metadata             Json?     // Store other preferences
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatFolder {
  id            String         @id @default(cuid())
  userId        String
  name          String
  parentId      String?        // For nested folders
  order         Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        ChatFolder?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children      ChatFolder[]   @relation("FolderHierarchy")
  conversations Conversation[]

  @@unique([userId, name, parentId])
  @@index([userId])
  @@index([parentId])
}

model SavedPrompt {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  tags      String[] // Array of tags for organization
  favorite  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, favorite])
}

model SharedConversation {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  token          String       @unique // Public share token
  expiresAt      DateTime?
  viewCount      Int          @default(0)
  revokedAt      DateTime?
  passwordHash   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([token])
}

model ChatUsageLog {
  id             String    @id @default(cuid())
  userId         String
  conversationId String?
  model          ChatModel
  promptTokens   Int
  completionTokens Int
  totalTokens    Int
  cost           Float?    // Estimated cost in USD
  metadata       Json?     // Store request details
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([conversationId])
}

// ============================================
// PLATFORM SERVICE ACCESS CONTROL
// ============================================

model UserServiceAccess {
  id        String      @id @default(cuid())
  userId    String
  service   ServiceType
  enabled   Boolean     @default(true)
  metadata  Json?       // Store service-specific settings
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service])
  @@index([userId])
  @@index([service])
}
